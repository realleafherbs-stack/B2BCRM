generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  EDITOR
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

enum FieldType {
  TEXT
  TEXTAREA
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?
  role          Role      @default(EDITOR)
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Site {
  id                   String            @id @default(cuid())
  name                 String
  slug                 String            @unique
  apiKey               String            @unique @default(cuid())
  revalidateSecret     String            @default(cuid())
  revalidateUrl        String?
  payperWebhookSecret  String?
  payperCategories     String[]          @default([])
  payperApiKey         String?
  payperAccount        String?
  createdAt            DateTime          @default(now())
  blogs                BlogPost[]
  textFields           TextField[]
  siteSeo              SiteSEO?
  submissions          FormSubmission[]
  reviews              Review[]
  orders               Order[]
  coupons              Coupon[]
  products             Product[]
  categories           Category[]
}

model Category {
  id        String    @id @default(cuid())
  siteId    String
  name      String
  slug      String
  order     Int       @default(0)
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  site      Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([siteId, slug])
  @@index([siteId])
}

model Order {
  id              String   @id
  siteId          String
  status          String   @default("pending")
  total           Float
  shipping        Float    @default(0)
  discount        Float    @default(0)
  customerName    String
  customerEmail   String
  customerPhone   String
  customerAddress String
  items           Json
  payperDocId     String?
  customerNote    String?   @db.Text
  shippingNote    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  site            Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, createdAt])
  @@index([siteId, status])
}

model Coupon {
  id        String    @id @default(cuid())
  siteId    String
  code      String
  type      String    @default("PERCENT")
  value     Float
  expiresAt DateTime?
  maxUses   Int?
  usedCount Int       @default(0)
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  site      Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, code])
  @@index([siteId])
}

model Product {
  id              String    @id @default(cuid())
  siteId          String
  handle          String
  name            String
  price           Float
  description     String?
  badge           String?
  image           String?
  images          String[]  @default([])
  payperSku       String?
  cardFeatures    String[]  @default([])
  features        String[]  @default([])
  active          Boolean   @default(true)
  order           Int       @default(0)
  metaTitle         String?
  metaDescription   String?
  ogImage           String?
  categoryId        String?
  videoUrl          String?
  soldCount         String?
  rating            Float?
  reviewCount       Int?
  specsRaw          String?   @db.Text
  inTheBox          String?   @db.Text
  usageInstructions String?   @db.Text
  warrantyInfo      String?   @db.Text
  faqRaw            String?   @db.Text
  relatedProductIds String[]  @default([])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  site            Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  category        Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  reviews         Review[]

  @@unique([siteId, handle])
  @@index([siteId])
  @@index([categoryId])
}

model Review {
  id        String   @id @default(cuid())
  siteId    String
  productId String
  name      String
  rating    Int
  text      String   @db.Text
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([siteId, productId])
}

model FormSubmission {
  id        String   @id @default(cuid())
  siteId    String
  name      String
  email     String
  phone     String?
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, createdAt])
}

model TextField {
  id        String    @id @default(cuid())
  siteId    String
  key       String
  label     String
  value     String    @default("") @db.Text
  type      FieldType @default(TEXT)
  page      String    @default("general")
  order     Int       @default(0)
  site      Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, key])
}

model BlogPost {
  id              String     @id @default(cuid())
  siteId          String
  title           String
  slug            String
  body            String     @default("") @db.Text
  status          PostStatus @default(DRAFT)
  publishedAt     DateTime?
  featuredImage   String?
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  tags            String[]   @default([])
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  site            Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, slug])
  @@index([siteId, status])
  @@index([siteId, publishedAt])
}

model SiteSEO {
  id              String  @id @default(cuid())
  siteId          String  @unique
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  schemaLogo      String?
  schemaSameAs    String? @db.Text
  site            Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
}
